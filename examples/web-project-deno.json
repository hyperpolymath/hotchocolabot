{
  "// NOTE": "Example deno.json for AffineScript web projects",
  "tasks": {
    "build": "affinescript compile .",
    "build-release": "affinescript compile --release .",
    "check": "affinescript check .",
    "clean": "affinescript clean .",
    "watch": "affinescript compile -w .",
    "serve": "deno run -A jsr:@std/http/file-server .",
    "test": "deno test --allow-all"
  },
  "imports": {
    "affinescript": "npm:@hyperpolymath/affinescript",
    "@hyperpolymath/affinescript": "npm:@hyperpolymath/affinescript",
    "@hyperpolymath/affine-js": "https://raw.githubusercontent.com/hyperpolymath/affinescript/main/packages/affine-js/src/mod.js",
    "safe-dom/": "https://raw.githubusercontent.com/hyperpolymath/affine-dom/main/src/",
    "proven/": "../proven/bindings/affinescript/src/"
  },
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false
  }
}
